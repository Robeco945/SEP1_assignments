pipeline {
    agent any

    environment {
        IMAGE_NAME            = 'temperature-converter'
        IMAGE_TAG             = "${env.BUILD_NUMBER}"
        // ── Docker Hub ── set to your Docker Hub username/repo ──────────────
        DOCKERHUB_CREDENTIALS = 'dockerhub-credentials'   // Jenkins credential ID
    }

    stages {

        // ── 1. Checkout ───────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ── 2. Build the Docker image ─────────────────────────────────────────
        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        Junit_w3
                """
            }
        }

        // ── 3. Run tests inside the container & produce JaCoCo report ─────────
        //        We cannot use a bind-mount here because Jenkins itself runs
        //        inside Docker (named volume), so the path it knows is not on
        //        the host. Instead: run the container, then docker cp the
        //        target/ directory into the Jenkins workspace.
        stage('Run Tests & Generate JaCoCo Report') {
            steps {
                sh """
                    docker run --name tc-${IMAGE_TAG} ${IMAGE_NAME}:${IMAGE_TAG}
                    docker cp tc-${IMAGE_TAG}:/app/target ${WORKSPACE}/Junit_w3/
                    docker rm tc-${IMAGE_TAG}
                """
            }

            post {
                always {
                    // Archive JaCoCo exec file and HTML report as build artifacts
                    archiveArtifacts artifacts: 'Junit_w3/target/jacoco.exec, Junit_w3/target/site/jacoco/**',
                                     allowEmptyArchive: true

                    // Archive surefire XML so Jenkins shows test results
                    junit 'Junit_w3/target/surefire-reports/TEST-*.xml'
                }
            }
        }

        // ── 4. (Optional) Push image to Docker Hub ────────────────────────────
        //        Runs only on main / master branches.
        //        Requires a Jenkins "Username with password" credential whose ID
        //        matches DOCKERHUB_CREDENTIALS above.
        stage('Push to Docker Hub') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKERHUB_CREDENTIALS}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} "\${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} "\${DOCKER_USER}/${IMAGE_NAME}:latest"
                        docker push "\${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                        docker push "\${DOCKER_USER}/${IMAGE_NAME}:latest"
                        docker logout
                    """
                }
            }
        }
    }

    // ── Global post actions ───────────────────────────────────────────────────
    post {
        always {
            // Remove local images to keep the Docker daemon clean
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest || true"
        }
        success {
            echo "Pipeline completed successfully. JaCoCo report available in the build artifacts."
        }
        failure {
            echo "Pipeline failed. Check the console output for details."
        }
    }
}
