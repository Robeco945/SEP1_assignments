pipeline {
    agent any

    environment {
        IMAGE_NAME            = 'temperature-converter'
        IMAGE_TAG             = "${env.BUILD_NUMBER}"
        // ── Docker Hub ── set to your Docker Hub username/repo ──────────────
        DOCKERHUB_CREDENTIALS = 'dockerhub-credentials'   // Jenkins credential ID
    }

    stages {

        // ── 1. Checkout ───────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ── 2. Build the Docker image ─────────────────────────────────────────
        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        .
                """
            }
        }

        // ── 3. Run tests inside the container & produce JaCoCo report ─────────
        //        The workspace target/ directory is bind-mounted so that Maven
        //        writes jacoco.exec, surefire XML, and the HTML report directly
        //        into the Jenkins workspace (needed for post-build publishers).
        stage('Run Tests & Generate JaCoCo Report') {
            steps {
                sh """
                    docker run --rm \
                        -v "${WORKSPACE}/target:/app/target" \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }

            post {
                always {
                    // Publish JaCoCo coverage (requires the Jenkins JaCoCo plugin)
                    jacoco(
                        execPattern:      'target/jacoco.exec',
                        classPattern:     'target/classes',
                        sourcePattern:    'src/main/java',
                        exclusionPattern: 'src/test*'
                    )

                    // Archive the generated HTML report (requires HTML Publisher plugin)
                    publishHTML(target: [
                        allowMissing:          false,
                        alwaysLinkToLastBuild: true,
                        keepAll:               true,
                        reportDir:             'target/site/jacoco',
                        reportFiles:           'index.html',
                        reportName:            'JaCoCo Coverage Report'
                    ])

                    // Archive surefire XML so Jenkins shows test results
                    junit 'target/surefire-reports/TEST-*.xml'
                }
            }
        }

        // ── 4. (Optional) Push image to Docker Hub ────────────────────────────
        //        Runs only on main / master branches.
        //        Requires a Jenkins "Username with password" credential whose ID
        //        matches DOCKERHUB_CREDENTIALS above.
        stage('Push to Docker Hub') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKERHUB_CREDENTIALS}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} "\${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} "\${DOCKER_USER}/${IMAGE_NAME}:latest"
                        docker push "\${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                        docker push "\${DOCKER_USER}/${IMAGE_NAME}:latest"
                        docker logout
                    """
                }
            }
        }
    }

    // ── Global post actions ───────────────────────────────────────────────────
    post {
        always {
            // Remove local images to keep the Docker daemon clean
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest || true"
        }
        success {
            echo "Pipeline completed successfully. JaCoCo report available in the build artifacts."
        }
        failure {
            echo "Pipeline failed. Check the console output for details."
        }
    }
}
