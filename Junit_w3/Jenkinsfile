pipeline {
    agent any

    environment {
        IMAGE_NAME            = 'temperature-converter'
        IMAGE_TAG             = "${env.BUILD_NUMBER}"
        DOCKERHUB_CREDENTIALS = 'dockerhub-credentials'   
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        Junit_w3
                """
            }
        }

        stage('Run Tests & Generate JaCoCo Report') {
            steps {
                sh """
                    docker run --name tc-${IMAGE_TAG} ${IMAGE_NAME}:${IMAGE_TAG}
                    docker cp tc-${IMAGE_TAG}:/app/target ${WORKSPACE}/Junit_w3/
                    docker rm tc-${IMAGE_TAG}
                """
            }

            
            post {
                always {
                    jacoco(
                        execPattern: 'Junit_w3/target/jacoco.exec',
                        classPattern: 'Junit_w3/target/classes',
                        sourcePattern: 'Junit_w3/src/main/java',
                        inclusionPattern: '**/*.class'
                    )

                    publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'Junit_w3/target/site/jacoco',
                    reportFiles: 'index.html',
                    reportName: 'JaCoCo HTML Report'
                ])

                junit 'Junit_w3/target/surefire-reports/TEST-*.xml'
            }
        }
           
        }

        stage('Push to Docker Hub') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKERHUB_CREDENTIALS}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} "\${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} "\${DOCKER_USER}/${IMAGE_NAME}:latest"
                        docker push "\${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
                        docker push "\${DOCKER_USER}/${IMAGE_NAME}:latest"
                        docker logout
                    """
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest || true"
        }
        success {
            echo "Pipeline completed successfully. JaCoCo report available in the build artifacts."
        }
        failure {
            echo "Pipeline failed. Check the console output for details."
        }
    }
}
