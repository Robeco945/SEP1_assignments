<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox" alignment="TOP_CENTER" prefHeight="620.0" prefWidth="520.0" spacing="14.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="sep2.shoppingcart.ShoppingCartController"
      styleClass="root">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label fx:id="lblTitle" styleClass="title" text="Shopping Cart"/>

    <VBox spacing="8.0" styleClass="card">
        <Label fx:id="lblLanguage" text="Language"/>
        <Button fx:id="btnLanguage" prefWidth="220.0" onAction="#onToggleLanguageOptions" styleClass="dropdown-button"/>
        <VBox fx:id="languageOptionsBox" spacing="4.0" visible="false" managed="false" styleClass="language-options"/>

        <Label fx:id="lblNumItems" text="Number of items"/>
        <HBox spacing="8.0">
            <TextField fx:id="tfNumItems" promptText="e.g. 3"/>
            <Button fx:id="btnPrepareItems" mnemonicParsing="false" onAction="#onPrepareItemsClick" text="Prepare Items" styleClass="primary-button"/>
        </HBox>

        <Label fx:id="lblItemsHeader" text="Item Inputs"/>
        <ScrollPane fitToWidth="true" prefHeight="260.0" styleClass="items-scroll">
            <content>
                <VBox fx:id="itemsContainer" spacing="8.0" styleClass="items-box"/>
            </content>
        </ScrollPane>

        <Button fx:id="btnCalculateAll" mnemonicParsing="false" onAction="#onCalculateAllClick" text="Calculate Totals" styleClass="primary-button"/>
    </VBox>

    <Label fx:id="lblResult" styleClass="result" text=""/>
    <Label fx:id="lblLocalTime" styleClass="time" text=""/>
</VBox>
